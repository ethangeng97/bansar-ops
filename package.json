{
  "name": "bansar-ops",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "copy-pdfjs-cmaps": "node -e \"require('fs').cpSync('node_modules/pdfjs-dist/cmaps','public/pdfjs-cmaps',{recursive:true,force:true})\"",
    "predev": "npm run copy-pdfjs-cmaps",
    "prebuild": "npm run copy-pdfjs-cmaps",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  }
}
